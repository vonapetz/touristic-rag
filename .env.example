# === LLM ===
LLM_PROVIDER=local
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen3:14b

LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# === Embeddings ===
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DEVICE=cpu

# === Retrieval ===
RETRIEVAL_K_INITIAL=10
RETRIEVAL_K_FINAL=3

# RRF параметр (стандартное значение — не менять без необходимости)
RRF_K=60

# Контекст для LLM (в символах)
MAX_CONTEXT_CHARS=3000

# Score threshold для cross-encoder (logit scale; -2.0 = умеренный фильтр)
RERANKER_SCORE_THRESHOLD=-2.0

# === Qdrant ===
QDRANT_URL=YOUR_QDRANT_URL
QDRANT_API_KEY=YOUR_QDRANT_API_KEY
QDRANT_COLLECTION=landmarks

# === Reranker ===
# SOTA multilingual reranker 2024 (лучше для русского языка)
RERANKER_TYPE=cross-encoder
CROSS_ENCODER_MODEL=BAAI/bge-reranker-v2-m3

# === Data ===
DATA_URL=https://drive.google.com/uc?id=1P1BsvI2jPN3fEqjc2YZxmQ-MTs22WVUk
DATA_PATH=data/raw/file.csv
PROCESSED_DATA_PATH=data/processed/final_clean_data.csv

# === Server ===
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Security ===
# В prod заменить на конкретные домены: ["https://yourdomain.com"]
CORS_ORIGINS=["*"]
# Rate limit на /v1/query
RATE_LIMIT=20/minute
# Включить /v1/config endpoint (только для разработки!)
DEBUG_MODE=false

# === Caching ===
QUERY_CACHE_TTL=3600
QUERY_CACHE_MAX_SIZE=500

# === Persistence ===
FEEDBACK_DB_PATH=data/feedback.db
BM25_CACHE_PATH=data/processed/bm25.pkl
# Принудительно пересобрать BM25 индекс при следующем старте
FORCE_REBUILD_BM25=false

# === Cleanup (TF-IDF) ===
TFIDF_MIN_DF=3
TFIDF_MAX_DF=0.7
TFIDF_SUSPICIOUS_LOW=0.001
TFIDF_SUSPICIOUS_HIGH=200
MIN_DESCRIPTION_LENGTH=10
