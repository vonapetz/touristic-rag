# === LLM ===
LLM_PROVIDER=local
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen3:14b

LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# === Embeddings ===
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DEVICE=cpu

# === Retrieval ===
RETRIEVAL_K_INITIAL=10
RETRIEVAL_K_FINAL=3
BM25_WEIGHT=0.4
VECTOR_WEIGHT=0.6

# === Qdrant ===
QDRANT_URL=YOUR_QDRANT_URL
QDRANT_API_KEY=YOUR_QDRANT_API_KEY
QDRANT_COLLECTION=landmarks

# === Reranker ===
RERANKER_TYPE=cross-encoder
CROSS_ENCODER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
COHERE_API_KEY=

# === Data ===
DATA_URL=https://drive.google.com/uc?id=1P1BsvI2jPN3fEqjc2YZxmQ-MTs22WVUk
DATA_PATH=data/raw/file.csv
PROCESSED_DATA_PATH=data/processed/final_clean_data.csv

# === Server ===
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Cleanup ===
TFIDF_MIN_DF=10
TFIDF_MAX_DF=0.1
TFIDF_SUSPICIOUS_LOW=0.001
TFIDF_SUSPICIOUS_HIGH=50
MIN_DESCRIPTION_LENGTH=10